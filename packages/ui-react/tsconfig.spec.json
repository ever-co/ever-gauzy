{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"module": "preserve",
		"target": "es2016",
		"types": ["jest", "node"],
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"jsx": "react-jsx"
	},
	"files": ["src/test-setup.ts"],
	"include": ["jest.config.ts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.test.tsx", "src/**/*.spec.tsx", "src/**/*.d.ts"]
}
