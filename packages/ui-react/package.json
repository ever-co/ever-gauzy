	"description": "React-to-Angular bridge for Gauzy UI plugins. Renders React components inside Angular with access to Angular services.",
	"author": {
		"name": "Ever Co. LTD",
		"email": "ever@ever.co",
		"url": "https://ever.co"
	},
	"repository": {
		"type": "git",
