{
	"name": "file-wasabi-s3",
	"$schema": "../../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/modules/providers/file-wasabi-s3/src",
	"projectType": "library",
	"release": {
		"version": {
			"currentVersionResolver": "git-tag",
			"preserveLocalDependencyProtocols": false,
			"manifestRootsToUpdate": ["dist/{projectRoot}"]
		}
	},
	"tags": [],
	"implicitDependencies": [],
	"targets": {
		"build": {
			"executor": "@nx/js:tsc",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/packages/modules/providers/file-wasabi-s3",
				"tsConfig": "packages/modules/providers/file-wasabi-s3/tsconfig.lib.json",
				"packageJson": "packages/modules/providers/file-wasabi-s3/package.json",
				"main": "packages/modules/providers/file-wasabi-s3/src/index.ts",
				"assets": ["packages/modules/providers/file-wasabi-s3/*.md"]
			}
		},
		"nx-release-publish": {
			"options": {
				"packageRoot": "dist/{projectRoot}"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint"
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "packages/modules/providers/file-wasabi-s3/jest.config.ts"
			}
		}
	}
}
