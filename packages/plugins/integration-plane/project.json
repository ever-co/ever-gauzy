{
	"name": "plugin-integration-plane",
	"$schema": "../../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/plugins/integration-plane/src",
	"projectType": "library",
	"release": {
		"version": {
			"manifestRootsToUpdate": ["dist/{projectRoot}"],
			"currentVersionResolver": "git-tag",
			"fallbackCurrentVersionResolver": "disk"
		}
	},
	"tags": [],
	"targets": {
		"build": {
			"executor": "@nx/js:tsc",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/packages/plugins/integration-plane",
				"tsConfig": "packages/plugins/integration-plane/tsconfig.lib.json",
				"packageJson": "packages/plugins/integration-plane/package.json",
				"main": "packages/plugins/integration-plane/src/index.ts",
				"assets": ["packages/plugins/integration-plane/*.md"]
			}
		},
		"nx-release-publish": {
			"options": {
				"packageRoot": "dist/{projectRoot}"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint"
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "packages/plugins/integration-plane/jest.config.ts"
			}
		}
	}
}
