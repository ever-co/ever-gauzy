{
    "printWidth": 120,
    "singleQuote": true,
    "semi": true,
    "useTabs": true,
    "tabWidth": 4,
    "arrowParens": "always",
    "trailingComma": "none",
    "quoteProps": "as-needed",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": "*.scss",
            "options": {
                "useTabs": false,
                "tabWidth": 2
            }
        },
        {
            "files": "*.yml",
            "options": {
                "useTabs": false,
                "tabWidth": 2
            }
        }
    ]
}
