{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "../../dist/out-tsc",
		"types": [
			"node",
			"google.maps"
		]
	},
	"files": [
		"src/main.ts",
		"src/polyfills.ts",
		"src/app/date-holidays.mock.ts"
	],
	"include": [
		"src/**/*.d.ts"
	],
	"exclude": [
		"jest.config.ts",
		"src/**/*.test.ts",
		"src/**/*.spec.ts"
	]
}
